# Path to the project to mount into the container
PROJECT_PATH=C:\Users\<user>\Documents\Sources\mon-projet

# Path to user profile directory (contains .claude/)
CLAUDE_HOME=C:\Users\<user>

# Optional: GitHub token for GitHub MCP server and gh CLI
GITHUB_TOKEN=

# Optional: Brave Search API key for web search MCP server
BRAVE_API_KEY=

# Optional: Database connection string for database work
DATABASE_URL=

# Claude Code OAuth token (fallback : utilise uniquement si les credentials
# de l'hote ne sont pas disponibles, ex: CI). En usage normal, les credentials
# sont auto-detectees depuis l'installation Claude Code de l'hote.
# Generer avec : claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: Path to host NuGet.Config (auto-detected by launchers)
# Laisser vide pour auto-detection depuis %APPDATA%\NuGet\NuGet.Config
NUGET_CONFIG_PATH=

# Optional: PAT pour les feeds NuGet prives (GitLab, Azure DevOps, GitHub Packages)
# Remplace les credentials DPAPI (Windows) qui ne fonctionnent pas dans le conteneur Linux
NUGET_PRIVATE_FEED_PAT=

# Optional: Set to "false" to skip Chromium installation (saves ~500MB)
INSTALL_CHROMIUM=true

# Optional: Force rebuild of all configs from host (ignores persistent volume)
CLAUDE_FORCE_RESEED=

# Optional: Container resource limits
MEMORY_LIMIT=8G
CPU_LIMIT=4.0
